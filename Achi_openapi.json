{
  "openapi": "3.1.0",
  "info": {
    "title": "KMP Achievements Backend",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "https://lucky-eminent-gator.ngrok-free.app",
      "description": "Production/Public Server (via ngrok)"
    },
    {
      "url": "http://127.0.0.1:8000",
      "description": "Local Development Server"
    }
  ],
  "paths": {
    "/upload/image": {
      "post": {
        "tags": [
          "Upload"
        ],
        "summary": "Upload Image",
        "description": "Upload an image and return its URL.\nThe image will be saved to static/images/{subdir}/ directory.",
        "operationId": "upload_image_upload_image_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_image_upload_image_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {

                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "OAuth2PasswordBearer": []
          }
        ]
      }
    },
    "/achievements": {
      "post": {
        "tags": [
          "Achievements"
        ],
        "summary": "Create Achievement",
        "operationId": "create_achievement_achievements_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AchievementCreateBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AchievementSchema"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "OAuth2PasswordBearer": []
          }
        ]
      }
    },
    "/achievements/{achievement_id}": {
      "get": {
        "tags": [
          "Achievements"
        ],
        "summary": "Get Achievement",
        "operationId": "get_achievement_achievements__achievement_id__get",
        "parameters": [
          {
            "name": "achievement_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Achievement Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AchievementSchema"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/packs": {
      "post": {
        "tags": [
          "Packs"
        ],
        "summary": "Create Pack",
        "operationId": "create_pack_packs_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AchievementPackCreateBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AchievementPackSchema"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "OAuth2PasswordBearer": []
          }
        ]
      }
    },
    "/packs/{pack_code}": {
      "get": {
        "tags": [
          "Packs"
        ],
        "summary": "Get Pack",
        "operationId": "get_pack_packs__pack_code__get",
        "parameters": [
          {
            "name": "pack_code",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Pack Code"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AchievementPackSchema"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/packs/by-id/{pack_id}": {
      "get": {
        "tags": [
          "Packs"
        ],
        "summary": "Get Pack By Id",
        "operationId": "get_pack_by_id_packs_by_id__pack_id__get",
        "parameters": [
          {
            "name": "pack_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Pack Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AchievementPackSchema"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AchievementCreateBody": {
        "properties": {
          "title": {
            "type": "string",
            "title": "Title"
          },
          "short_description": {
            "type": "string",
            "title": "Short Description"
          },
          "long_description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Long Description"
          },
          "preview_image_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Preview Image Url"
          },
          "image_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Image Url"
          },
          "steps": {
            "items": {
              "$ref": "#/components/schemas/AchievementStepCreate"
            },
            "type": "array",
            "title": "Steps"
          }
        },
        "type": "object",
        "required": [
          "title",
          "short_description",
          "steps"
        ],
        "title": "AchievementCreateBody"
      },
      "AchievementPackCreateBody": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "preview_image_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Preview Image Url"
          },
          "achievement_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Achievement Ids"
          }
        },
        "type": "object",
        "required": [
          "name",
          "achievement_ids"
        ],
        "title": "AchievementPackCreateBody"
      },
      "AchievementPackSchema": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "preview_image_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Preview Image Url"
          },
          "achievement_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Achievement Ids"
          },
          "id": {
            "type": "string",
            "title": "Id"
          },
          "code": {
            "type": "string",
            "title": "Code"
          },
          "count": {
            "type": "integer",
            "title": "Count"
          }
        },
        "type": "object",
        "required": [
          "name",
          "achievement_ids",
          "id",
          "code",
          "count"
        ],
        "title": "AchievementPackSchema"
      },
      "AchievementSchema": {
        "properties": {
          "title": {
            "type": "string",
            "title": "Title"
          },
          "short_description": {
            "type": "string",
            "title": "Short Description"
          },
          "long_description": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Long Description"
          },
          "preview_image_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Preview Image Url"
          },
          "image_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Image Url"
          },
          "id": {
            "type": "string",
            "title": "Id"
          },
          "steps": {
            "items": {
              "$ref": "#/components/schemas/AchievementStepSchema"
            },
            "type": "array",
            "title": "Steps"
          }
        },
        "type": "object",
        "required": [
          "title",
          "short_description",
          "id",
          "steps"
        ],
        "title": "AchievementSchema"
      },
      "AchievementStepCreate": {
        "properties": {
          "description": {
            "type": "string",
            "title": "Description"
          },
          "substeps_amount": {
            "type": "integer",
            "title": "Substeps Amount",
            "default": 1
          }
        },
        "type": "object",
        "required": [
          "description"
        ],
        "title": "AchievementStepCreate"
      },
      "AchievementStepSchema": {
        "properties": {
          "description": {
            "type": "string",
            "title": "Description"
          },
          "progress": {
            "$ref": "#/components/schemas/StepProgress"
          }
        },
        "type": "object",
        "required": [
          "description"
        ],
        "title": "AchievementStepSchema"
      },
      "Body_upload_image_upload_image_post": {
        "properties": {
          "image": {
            "type": "string",
            "format": "binary",
            "title": "Image"
          },
          "subdir": {
            "type": "string",
            "title": "Subdir",
            "default": "general"
          }
        },
        "type": "object",
        "required": [
          "image"
        ],
        "title": "Body_upload_image_upload_image_post"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "StepProgress": {
        "properties": {
          "substeps_done": {
            "type": "integer",
            "title": "Substeps Done",
            "default": 0
          },
          "substeps_amount": {
            "type": "integer",
            "title": "Substeps Amount",
            "default": 1
          }
        },
        "type": "object",
        "title": "StepProgress"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    },
    "securitySchemes": {
      "OAuth2PasswordBearer": {
        "type": "oauth2",
        "flows": {
          "password": {
            "scopes": {

            },
            "tokenUrl": "token"
          }
        }
      }
    }
  }
}